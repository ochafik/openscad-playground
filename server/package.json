{
  "name": "openscad-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc 1>&2",
    "start": "npm run start:http",
    "start:http": "node --import tsx index.ts",
    "start:stdio": "node --import tsx index.ts --stdio",
    "start:self-serve": "node --import tsx index.ts --serve-dist",
    "dev": "node --import tsx index.ts",
    "test": "node --import tsx test-e2e.ts",
    "test:redis": "REDIS_URL=redis://localhost:6399 node --import tsx test-e2e.ts",
    "redis": "docker run --rm -p 6399:6379 --name openscad-redis redis:7-alpine",
    "dev:redis": "npx concurrently -k -n redis,server -c magenta,cyan \"npm run redis\" \"npm run test:redis\""
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
