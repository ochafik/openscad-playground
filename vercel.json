{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install && cd server && npm install",
  "buildCommand": "bash scripts/vercel-prebuild.sh && cd server && npx esbuild vercel-entry.ts --bundle --platform=node --format=cjs --outfile=../api/_server.js && cd .. && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 60,
      "includeFiles": "api/_server.js"
    }
  },
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" }
  ],
  "headers": [
    {
      "source": "/mcp",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Accept, Mcp-Session-Id" }
      ]
    }
  ]
}
